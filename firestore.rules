rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is `uid` a member of `familyId`?
    function inFamily(familyId, uid) {
      return exists(/databases/$(database)/documents/families/$(familyId))
        && uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberUids;
    }

    // Helper: does the request's auth match a member of this family?
    function isFamilyMember(familyId) {
      return request.auth != null && inFamily(familyId, request.auth.uid);
    }

    // ── Users & owned sub-collections ──
    match /users/{uid} {
      // Family members need to read each other's profile (displayName, photo)
      // to render member lists / attribution. Email + tokens stay private
      // because Firestore rules can't filter fields — clients must request
      // only the fields they need (the AppUser type already excludes them
      // from rendered UI). For now, allow any signed-in user to read public
      // profile docs; tighten later if PII concerns emerge.
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow update: if request.auth.uid == uid;
      allow delete: if false;

      // ── Legacy paths removed 2026-05-23 ──
      // The pre-family schema kept pets/reminders/walks/expenses under
      // users/{uid}/... . Migration (Phase 3+4, see family-provider.tsx
      // historical) moved everything to top-level collections with a
      // `familyId` field. The legacy sub-collections were drained by the
      // cleanupLegacyPaths callable + admin-script
      // (legacyCleanups/2026-05-23T14-01-53-045Z audit doc), so the
      // corresponding match blocks have been removed.
      //
      // If you need to add a new sub-collection under users/{uid}, do so
      // here following the friends/friendRequests/favoriteRestaurants
      // pattern below, not the deleted legacy pattern.

      match /friends/{friendUid} {
        allow read: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
        allow write: if request.auth.uid == uid;
      }

      match /friendRequests/{requestId} {
        allow read: if request.auth.uid == uid;
        allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid
          && requestId == request.auth.uid;
        allow delete: if request.auth.uid == uid
          || request.auth.uid == requestId;
        allow update: if false;
      }

      match /favoriteRestaurants/{rid} {
        allow read, write: if request.auth.uid == uid;
      }

      match /knowledgeBookmarks/{articleId} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // ── Families ──
    // A family doc lists its members. Membership is a single source of truth
    // for all the family-scoped collections below.
    match /families/{familyId} {
      // Members can read their own family doc. The join-by-code path runs
      // server-side in a Cloud Function, so non-members never need read here.
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // No client writes — every create/update/delete goes through callables
      // (createFamily / joinFamilyByCode / leaveFamily / regenerateInviteCode
      // / removeFamilyMember). This keeps inviteCode generation, member
      // invariants, and last-member cleanup atomic and auditable.
      allow create, update, delete: if false;

      // Audit log for callable-driven family migrations (import-personal in
      // Phase B3, pet-merge in B4, future dedupe-migration). Members can
      // read their family's audit trail; writes go only through Admin SDK
      // in the callables.
      match /migrations/{migrationId} {
        allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/families/$(familyId)).data.memberUids;
        allow write: if false;
      }
    }

    // ── Family-scoped top-level collections ──
    // Two access modes per doc:
    //   1. FAMILY: `data.familyId != null` — any member of that family.
    //   2. PERSONAL: `data.familyId == null` — only the doc's owner
    //      (`ownerUid` / `walkerUid` / `createdByUid` / `payerUid` per
    //      collection; the canonical field is whatever the matching
    //      `create` rule already required for that collection).
    // Personal mode is the no-family default after onboarding; users
    // can migrate personal docs into a family later via the
    // `importPersonalToFamily` callable (Phase B3).
    //
    // Per-collection personal-owner predicates. We inline the field name
    // (rather than parameterising) because Firestore rules' dynamic field
    // access (`data[varName]`) is not documented to work reliably across
    // SDK versions — explicit predicates compile and behave the same way
    // every release.
    function isPersonalPetOwner(d) {
      return d.familyId == null && request.auth != null
        && d.ownerUid == request.auth.uid;
    }
    function isPersonalWalkOwner(d) {
      return d.familyId == null && request.auth != null
        && d.walkerUid == request.auth.uid;
    }
    function isPersonalReminderOwner(d) {
      return d.familyId == null && request.auth != null
        && d.createdByUid == request.auth.uid;
    }
    function isPersonalExpenseOwner(d) {
      return d.familyId == null && request.auth != null
        && d.payerUid == request.auth.uid;
    }

    // NOTE on `resource == null` clauses:
    //   The migration helpers call getDoc() to check whether a top-level
    //   doc with the same id as a legacy doc exists yet. When it doesn't,
    //   Firestore evaluates the rule with `resource == null`, and
    //   `resource.data.familyId` is undefined → permission denied. Allowing
    //   read of non-existing docs (which leak nothing — the snapshot just
    //   says "doesn't exist") fixes this and is a standard Firestore
    //   pattern for "did this doc get created yet?" checks. The `list`
    //   query for family pets/walks/etc. still uses the familyId filter
    //   so non-family members can't enumerate.

    match /pets/{petId} {
      allow read: if resource == null
        || isPersonalPetOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && (
          request.resource.data.familyId == null
          || isFamilyMember(request.resource.data.familyId)
        );
      allow update: if (
          isPersonalPetOwner(resource.data)
          || isFamilyMember(resource.data.familyId)
        )
        && (
          // Post-state must also be accessible to the caller — either
          // still personal-owned-by-self, or in a family we belong to.
          isPersonalPetOwner(request.resource.data)
          || isFamilyMember(request.resource.data.familyId)
        );
      allow delete: if isPersonalPetOwner(resource.data)
        || isFamilyMember(resource.data.familyId);

      // Health records flattened to a subcollection of pet at top-level.
      // Both reads and writes gated by the parent pet's family — or by
      // the parent pet's ownerUid in personal mode.
      match /healthRecords/{recordId} {
        allow read, write: if resource == null
          || isPersonalPetOwner(
               get(/databases/$(database)/documents/pets/$(petId)).data
             )
          || isFamilyMember(
               get(/databases/$(database)/documents/pets/$(petId)).data.familyId
             );
      }
    }

    match /walks/{walkId} {
      allow read: if resource == null
        || isPersonalWalkOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
      allow create: if request.auth != null
        && request.resource.data.walkerUid == request.auth.uid
        && (
          request.resource.data.familyId == null
          || isFamilyMember(request.resource.data.familyId)
        );
      // Updates allowed by the walker only (e.g., editing notes), in
      // both family and personal modes (walker == self covers both).
      allow update: if request.auth.uid == resource.data.walkerUid;
      allow delete: if isPersonalWalkOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
    }

    match /reminders/{reminderId} {
      allow read: if resource == null
        || isPersonalReminderOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
      allow create: if request.auth != null
        && request.resource.data.createdByUid == request.auth.uid
        && (
          request.resource.data.familyId == null
          || isFamilyMember(request.resource.data.familyId)
        );
      // Any family member can mark done / edit / delete in family mode;
      // only the owner in personal mode. The doneByUid anti-impersonation
      // guard applies in both modes — if the update touches doneByUid it
      // must be cleared or equal request.auth.uid.
      allow update: if (
          isPersonalReminderOwner(resource.data)
          || isFamilyMember(resource.data.familyId)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["doneByUid"])
          || !("doneByUid" in request.resource.data)
          || request.resource.data.doneByUid == request.auth.uid
        );
      allow delete: if isPersonalReminderOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
    }

    match /expenses/{expenseId} {
      allow read: if resource == null
        || isPersonalExpenseOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
      allow create: if request.auth != null
        && request.resource.data.payerUid == request.auth.uid
        && (
          request.resource.data.familyId == null
          || isFamilyMember(request.resource.data.familyId)
        );
      // Payer edits their own expense in both modes. Family members
      // can delete bad entries in family mode; personal owner deletes
      // in personal mode.
      allow update: if request.auth.uid == resource.data.payerUid;
      allow delete: if isPersonalExpenseOwner(resource.data)
        || isFamilyMember(resource.data.familyId);
    }

    // ── Posts (top-level, author-owned, friend/public visibility) ──
    function isFriend(authorUid, viewerUid) {
      return exists(/databases/$(database)/documents/users/$(authorUid)/friends/$(viewerUid));
    }

    match /posts/{postId} {
      allow read: if request.auth != null && (
        resource.data.visibility == "public"
        || resource.data.authorUid == request.auth.uid
        || (resource.data.visibility == "friends"
            && isFriend(resource.data.authorUid, request.auth.uid))
      );

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.visibility in ["private", "friends", "public"];

      allow update: if request.auth != null && (
        resource.data.authorUid == request.auth.uid
        || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["reactionCounts"]))
      );

      allow delete: if request.auth.uid == resource.data.authorUid;

      match /reactions/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == uid;
      }
    }

    // ── Restaurants & reviews ──
    match /restaurants/{rid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.submittedByUid == request.auth.uid;
      allow update, delete: if false;

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth.uid == resource.data.authorUid;
      }
    }

    // ── Knowledge articles (public read, admin write later) ──
    match /knowledgeArticles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Leaderboards (read-anyone, write only via Cloud Functions) ──
    match /leaderboards/{period} {
      allow read: if request.auth != null;
      allow write: if false;

      match /entries/{uid} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ── deletedAccounts audit log (admin/server-only) ──
    // Written by the deleteUserAccount callable via Admin SDK (rules
    // bypass). No client read/write — the deleting user is gone before
    // the doc exists, and nobody else has a legitimate reason to inspect
    // these records from the client (admin tooling can use the console).
    match /deletedAccounts/{id} {
      allow read, write: if false;
    }

    // ── legacyCleanups audit log (admin/server-only) ──
    // Written by the cleanupLegacyPaths callable + matching admin script
    // (functions/scripts/run-legacy-cleanup.mjs) via Admin SDK. Same
    // posture as deletedAccounts — admin-only, inspectable via Firebase
    // Console; no client surface.
    match /legacyCleanups/{id} {
      allow read, write: if false;
    }

    // ── displayNameLowerBackfills audit log (admin/server-only) ──
    // Written by the backfillDisplayNameLower callable + matching admin
    // script (functions/scripts/run-backfill-display-name-lower.mjs) via
    // Admin SDK. Same posture as deletedAccounts / legacyCleanups —
    // admin-only, inspectable via Firebase Console; no client surface.
    match /displayNameLowerBackfills/{id} {
      allow read, write: if false;
    }

    // ── engagementPushes audit log (admin/server-only) ──
    // Written by the scheduled engagement-push functions
    // (eveningWalkReminder / streakBreakWarning / aggregateLeaderboards
    // rank-overtake branch / familyGoalMilestone) via Admin SDK. One
    // doc per push wave keyed by {type}/{ISO} so we can audit who
    // received what. Same client-locked posture as the other audit
    // collections above. Spec docs/features/
    // engagement-push-notifications.md Phase 4.
    match /engagementPushes/{document=**} {
      allow read, write: if false;
    }

    // ── realtimeLeaderboardUpdates audit log (admin/server-only) ──
    // Written by the recomputeWalkerLeaderboards onCreate(walks/{walkId})
    // trigger via Admin SDK. One doc per trigger fire keyed by
    // {walkerUid}_{ISO} so we can spot-check that a given walk
    // triggered the expected score recompute. Spec docs/features/
    // family-leaderboard-realtime.md.
    match /realtimeLeaderboardUpdates/{document=**} {
      allow read, write: if false;
    }

    // ── orphanWalkPurges audit log (server-only) ──
    // Written by the purgeMyOrphanWalks callable when a user cleans up
    // walks under a family they've left. One doc per invocation keyed
    // by {uid}_{ISO}, captures the orphan list even on dryRun.
    match /orphanWalkPurges/{document=**} {
      allow read, write: if false;
    }

    // ── autoFriendEvents audit log (server-only) ──
    // Written by the autoFriendFamilyMembers onWrite(families/{familyId})
    // trigger when new uids land in memberUids. One doc per fire keyed
    // by {familyId}_{ISO}; captures created/skipped pair counts +
    // reasons so we can spot abuse / runaway loops. Spec docs/features/
    // auto-friend-family-members.md.
    match /autoFriendEvents/{document=**} {
      allow read, write: if false;
    }

    // ── userDailyStats — per-user per-day flags (server writes only) ──
    // Currently holds the `goalHitNotifiedAt` field used by the B2
    // family-milestone push to dedupe (one push per achiever per day).
    // Doc id format: `{uid}_{YYYY-MM-DD}` so the lookup is a single
    // get() inside the trigger. Users can READ their own day to power
    // future client-side stats; writes are admin-only.
    match /userDailyStats/{statId} {
      // statId is "{uid}_{YYYY-MM-DD}". A safe id-prefix match keeps
      // user A from peeking at user B's stats while still allowing
      // simple client `getDoc()` reads of their own.
      allow read: if request.auth != null
        && statId.matches("^" + request.auth.uid + "_.*$");
      allow write: if false;
    }
  }
}
