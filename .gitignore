# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
__pycache__/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# claude code session state
.claude/

# firebase agent skills (per-user MCP config)
.agents/
skills-lock.json

# typescript
*.tsbuildinfo
next-env.d.ts

# generated FCM service worker (rebuilt by scripts/generate-fcm-sw.mjs)
/public/firebase-messaging-sw.js

# firebase
firebase-debug.log
firestore-debug.log
.firebase
/functions/lib
/functions/node_modules

# codex local build verification artifacts (kept out of repo + App Hosting
# build; Codex runs `npm install --prefix .codex-build-check` etc. when
# sanity-checking changes locally — those caches should never leak into
# the production build context)
/.codex-build-check/
/.codex-build-check.tar
/.codex-npm-cache/
